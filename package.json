{
  "name": "church-local-media-server",
  "version": "1.3.0",
  "private": true,
  "type": "module",
  "description": "Local-first church TV screen and media control system",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node server/index.js",
    "dev:client": "vite --host 0.0.0.0 --port 5174",
    "build": "vite build",
    "start": "node server/index.js",
    "start:prod": "NODE_ENV=production node server/index.js",
    "import:serbian": "node scripts/import-serbian-helloao.mjs",
    "import:serbian:choose": "SERBIAN_TRANSLATION_ID=PUT_ID_HERE node scripts/import-serbian-helloao.mjs",
    "import:serbian:sword": "node scripts/import-serbian-sword.mjs",
    "import:serbian:srponstl": "node scripts/import-serbian-srponstl.mjs",
    "import:songs": "node scripts/import-songs.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "lucide-react": "^0.468.0",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "qrcode": "^1.5.3",
    "vite": "^5.0.10",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {}
}