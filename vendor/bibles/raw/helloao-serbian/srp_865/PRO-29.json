  "chapter": {
    "number": 29,
    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "Èovjek koji po karanju ostaje tvrdoglav, ujedanput æe propasti, da neæe biti lijeka."
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "content": [
          "Kad se umnožavaju pravednici, veseli se narod; a kad vlada bezbožnik, uzdiše narod."
