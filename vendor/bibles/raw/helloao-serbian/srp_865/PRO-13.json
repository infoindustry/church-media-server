      {
        "type": "verse",
        "number": 10,
        "content": [
          "Od oholosti biva samo svaða, a koji primaju svjet, u njih je mudrost."
        ]
      },
      {
        "type": "verse",
        "number": 11,
        "content": [
          "Blago koje se taštinom teèe umaljava se, a ko sabira rukom, umnožava."
