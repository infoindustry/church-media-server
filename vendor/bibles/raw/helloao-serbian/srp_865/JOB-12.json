    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "A Jov odgovori i reèe:"
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "content": [
          "Da, vi ste ljudi, i s vama æe umrijeti mudrost."
