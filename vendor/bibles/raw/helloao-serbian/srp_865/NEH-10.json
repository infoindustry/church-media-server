        ]
      },
      {
        "type": "verse",
        "number": 9,
        "content": [
          "A Leviti: Isus sin Azanijin, Vinuj izmeðu sinova Inadadovijeh, Kadmilo,"
        ]
      },
      {
        "type": "verse",
        "number": 10,
        "content": [
          "I braæa njihova: Sevanija, Odija, Kelita, Felaja, Anan,"
        ]
      },
      {
        "type": "verse",
