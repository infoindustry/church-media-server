      },
      {
        "type": "verse",
        "number": 23,
        "content": [
          "Ti æeš ih, Bože, svaliti u jamu pogibli; krvopije i lukavi neæe sastaviti polovine dana svojih. A ja se u tebe uzdam."
        ]
      }
