  "chapter": {
    "number": 55,
    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "Usliši, Bože, molitvu moju, i nemoj se sakriti od moljenja mojega."
        ]
      },
      {
        "type": "verse",
