    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "I ovo su prièe Solomunove koje sabraše ljudi Jezekije cara Judina."
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "content": [
