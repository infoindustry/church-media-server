    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "A sada smiju mi se mlaði od mene, kojima otaca ne bih bio htio metnuti sa psima stada svojega."
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "content": [
