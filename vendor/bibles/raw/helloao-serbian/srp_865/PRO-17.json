      {
        "type": "verse",
        "number": 3,
        "content": [
          "Topionica je za srebro i peæ za zlato, a srca iskušava Gospod."
        ]
      },
      {
        "type": "verse",
        "number": 4,
        "content": [
          "Zao èovjek pazi na usne zle, a lažljivac sluša jezik pakostan."
