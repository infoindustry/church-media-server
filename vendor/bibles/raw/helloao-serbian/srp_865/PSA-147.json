  "chapter": {
    "number": 147,
    "content": [
      {
        "type": "verse",
        "number": 1,
        "content": [
          "Hvalite Gospoda, jer je slatko pjevati Boga našega, jer blagome prilikuje hvala."
        ]
      },
      {
        "type": "verse",
        "number": 2,
        "content": [
          "Gospod zida Jerusalim, sabira rasijane sinove Izrailjeve;"
        ]
      },
      {
        "type": "verse",
        "number": 3,
        "content": [
          "Iscjeljuje one koji su skrušena srca, i lijeèi tuge njihove;"
