      },
      {
        "type": "verse",
        "number": 19,
        "content": [
          "A poznata su djela tjelesna, koja su preljuboèinstvo, kurvarstvo, neèistota, besramnost,"
        ]
      },
      {
        "type": "verse",
        "number": 20,
        "content": [
