# Copy this file to .env on the mini-PC and fill in your key.
# .env is gitignored and never leaves the machine.

# OpenAI key with access to the realtime translation model.
OPENAI_API_KEY=

# Optional override of the realtime translation model id.
# OPENAI_REALTIME_MODEL=gpt-realtime-translate

# Google Gemini key for the Gemini Live Translate engine.
GEMINI_API_KEY=

# Optional override of the Gemini live-translate model id.
# GEMINI_REALTIME_MODEL=gemini-3.5-live-translate-preview

# Optional: change the server port (default 4000).
# PORT=4000

# Optional: enable Cloudflare transfer portal sync.
# CLOUD_SYNC_URL=https://church-media-cloud-portal.YOUR_SUBDOMAIN.workers.dev
# CLOUD_SYNC_DEVICE_ID=mini-pc-main
# CLOUD_SYNC_DEVICE_NAME=Church Mini PC
# CLOUD_SYNC_DEVICE_TOKEN=
# CLOUD_SYNC_INTERVAL_MS=10000
# CLOUD_SYNC_MAX_ITEMS=3


CLOUD_SYNC_URL=https://church-media-cloud-portal.infoindustry-russia.workers.dev
CLOUD_SYNC_DEVICE_ID=mini-pc-main
CLOUD_SYNC_DEVICE_NAME=Church Mini PC
CLOUD_SYNC_DEVICE_TOKEN=zrLdrKqFlpTen50Z5fywh3e6djf1GSkLLprOt5XiX5Crwj8QUM3jmqd94+7Yjxce
CLOUD_SYNC_INTERVAL_MS=10000
