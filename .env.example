# Copy this file to .env on the mini-PC and fill in your key.
# .env is gitignored and never leaves the machine.

# OpenAI key with access to the realtime translation model.
OPENAI_API_KEY=

# Optional override of the realtime translation model id.
# OPENAI_REALTIME_MODEL=gpt-realtime-translate

# Optional: change the server port (default 4000).
# PORT=4000
